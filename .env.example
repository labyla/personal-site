# PostgreSQL connection used by Payload CMS.
DATABASE_URL=postgres://personal_site:personal_site@db:5432/personal_site

# Required for Payload auth/session signing. Generate a real value with:
# openssl rand -base64 48
PAYLOAD_SECRET=change-me-generate-a-long-random-secret

# Optional local/schema controls.
PAYLOAD_DB_PUSH=false
PAYLOAD_BOOTSTRAP_CONTENT=true
NEXT_TELEMETRY_DISABLED=1

# Optional public runner settings for scripts/start-public.sh.
PORT=3000
APP_IMAGE=personal-site
APP_CONTAINER=personal-site-public
